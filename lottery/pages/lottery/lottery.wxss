page{
  height: 100%;
  width: 100%;
}
.title {
  font-size: 24px;
  font-weight: bold;
  margin-bottom: 20px;
}
.button {
  width: 200px;
  height: 60px;
  border-radius: 30px;
  font-size: 24px;
  color: #fff;
  background-color: #09bb07;
  margin-bottom: 20px;
}
.sign {
  font-size: 19px;
  color: #f00;
  text-align: center;
}
.loading {
  position: fixed;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}
.loading-image {
  width: 50px;
  height: 50px;
}
.container {
  background-color: #faf8ee;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
}
.logo {
  width: 100px;
  height: 100px;
  border-radius: 20px;
}
.load {
  text-align: center;
  margin-top: 10px;
}
.load text {
  display: inline-block;
  width: 6px;
  height: 6px;
  border: 1px solid #ccc;
  border-radius: 4px;
  margin: 0 5px;
}
.load text.sct {
  background-color: #ccc;
}
.imgnone{
  z-index: -1;
}
.image-container {
  display: flex;
  justify-content: center;
  margin-bottom: 20px;
}
.image-container image {
  width: 100px;
  height: 100px;
  margin: 0 10px;
}