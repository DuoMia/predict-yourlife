<view class="modal-mask" hidden="{{!showModal}}" bindtap="closeModal"></view>
<view class="modal" hidden="{{!showModal}}" style="width: 443rpx; height: 528rpx; box-sizing: border-box; left: 376rpx; top: 722rpx">
  <view class="modal-title" style="position: relative; left: 4rpx; top: -8rpx">{{title}}</view>
  <view class="modal-content">
    <block wx:for="{{options}}" wx:key="index">
      <view class="option" bindtap="selectOption" data-index="{{index}}">{{item}}</view>
    </block>
  </view>
</view>