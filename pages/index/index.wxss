/**index.wxss**/
.img{
  position:absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}
.container {
  background-color: #faf8ee;
  height: 100vh;
  width: 100vw;
  overflow: hidden;
  position: relative;
  display: flex;
}
.logo {
  width: 100px;
  height: 100px;
  border-radius: 20px;
}
.load {
  text-align: center;
  margin-top: 10px;
}
.load text {
  display: inline-block;
  width: 6px;
  height: 6px;
  border: 1px solid #ccc;
  border-radius: 4px;
  margin: 0 5px;
}
.load text.sct {
  background-color: #ccc;
}
.btn1{
  background-color: transparent;
  flex-grow: 60rpx;
  margin: auto;
  position: absolute;
  bottom: 52.5%;
  left: 0;
  right: 0;
}
