<view class="container" hidden="{{imgnoload}}">
  <view>
    <image class='logo' src='../image/xzbagua.png'></image>
    <view class='load'>
      <text class='{{current == 0 ? "sct": ""}}'></text>
      <text class='{{current == 1 ? "sct": ""}}'></text>
      <text class='{{current == 2 ? "sct": ""}}'></text>
      <text class='{{current == 3 ? "sct": ""}}'></text>
    </view>
  </view>
</view>
<view hidden="{{imgload}}">
  <image class="img" src="../image/选择入口.png" bindload="imgload"></image>
  <button class="btn1" bindtap="goto1" style="width: 230rpx;height: 90rpx;"></button>
  <button class="btn2" bindtap="goto2" style="width: 230rpx;height: 90rpx;"></button>
</view>