.time{
  display: flex;
}
.time_two{
  border: 1px solid #dddee1;
  box-shadow: 0 0 2px #dddee1;
}
.button1 {
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 32rpx;
  color: #333;
  background-color: #fff;
  border: 1rpx solid #ccc;
  border-radius: 100rpx;
  width: 620rpx;
  height: 115rpx;
  bottom:35% ;
  left: 0;
  right: 0;
  margin: auto;
  flex-grow: 115rpx;
  position: absolute;
}
.button2 {
  display: flex;
  position: absolute;
  justify-content: center;
  align-items: center;
  font-size: 32rpx;
  color: #333;
  background-color: #fff;
  border: 1rpx solid #ccc;
  border-radius: 100rpx;
  width: 620rpx;
  height: 115rpx;
  bottom:20% ;
  left: 0;
  right: 0;
  margin: auto;
  flex-grow: 115rpx;
  position: absolute;
}
.picker-text {
  font-size: 30rpx;
  color: #333;
}
.container {
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  display: flex;
  position: relative;
}
.image{
  left: 0;
  right: 0;
  width: 560rpx;
  height: 560rpx;
  margin: auto;
  flex-grow: 560rpx;
  bottom:50% ;
  position: absolute;
}
.start{
  margin: auto;
  flex-grow: 80rpx;
  position: absolute;
  border-radius: 60rpx;
  bottom:7% ;
  line-height: 80rpx;
}
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 99;
}
.modal {
  position: fixed;
  z-index: 100;
  top:8%
}
.modal-img{
  position: relative;
  height: 80vh;
  width: 90vw;
}
.modal-btn{
  flex-grow: 60rpx;
  margin: auto;
  position: absolute;
  bottom: 3%;
  left: 0;
  right: 0;
  z-index: 101;
  background-color: transparent;
}
.background{
  position:absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}
.turn{
  position: absolute;
  width: 100vw;
  height: 90rpx;
}
.left{
  height: 80rpx;
  width: 90rpx;
  z-index: 1;
  margin: auto;
  flex-grow: 200rpx;
  position: absolute;
  right: 27%;
}
.right{
  height: 80rpx;
  width: 90rpx;
  z-index: 1;
  margin: auto;
  flex-grow: 200rpx;
  position: absolute;
  left: 31%;
}
.btnexplain{
  position: absolute;
  margin: auto;
  right: 0;
  bottom: 88%;
}
.switch{
  position: absolute;
  margin: auto;
  left: 0;
  bottom: 88%;
  z-index: 1;
}